package com.cultureconnect.ComplianceAudit.serviceImpl;

import java.time.LocalDate;
import java.util.List;
import java.util.stream.Collectors;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;

import com.cultureconnect.ComplianceAudit.client.EventClient;
import com.cultureconnect.ComplianceAudit.client.GrantClient;
import com.cultureconnect.ComplianceAudit.client.ProgramClient;
import com.cultureconnect.ComplianceAudit.dto.ComplianceRequestDTO;
import com.cultureconnect.ComplianceAudit.dto.ComplianceResponseDTO;
import com.cultureconnect.ComplianceAudit.entity.ComplianceRecord;
import com.cultureconnect.ComplianceAudit.enums.ComplianceType;
import com.cultureconnect.ComplianceAudit.exception.ResourceNotFoundException;
import com.cultureconnect.ComplianceAudit.repository.ComplianceRecordRepository;
import com.cultureconnect.ComplianceAudit.repository.NewProgramRepository;
import com.cultureconnect.ComplianceAudit.service.ComplianceRecordService;

import feign.FeignException;

import com.cultureconnect.ComplianceAudit.dto.CulturalProgramRequestDto;
import com.cultureconnect.ComplianceAudit.dto.CulturalProgramResponseDto;
import com.cultureconnect.ComplianceAudit.entity.NewProgram;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class ComplianceRecordserviceImpl implements ComplianceRecordService {

    private static final Logger logger = LoggerFactory.getLogger(ComplianceRecordserviceImpl.class);
    private final ComplianceRecordRepository repository;
    private final NewProgramRepository newprogramrepository;
    
    // Feign Clients for Validation
    private final ProgramClient programClient;
    private final GrantClient grantClient;
    private final EventClient eventClient;

    @Override
    public ComplianceResponseDTO createCompliance(ComplianceRequestDTO requestDto) {

        logger.info(
            "Validating target entity: {} with ID: {}",
            requestDto.getType(),
            requestDto.getEntityId()
        );

        ComplianceType type = requestDto.getType();

        // Step 1: External Validation via Feign
        try {
            switch (type) {
                case PROGRAM ->
                    programClient.getProgramById(requestDto.getEntityId());

                case GRANT ->
                    grantClient.getGrantById(requestDto.getEntityId());

                case EVENT ->
                    eventClient.getEventsByProgramId(requestDto.getEntityId());

                default ->
                    throw new IllegalArgumentException("Unsupported Compliance Type: " + type);
            }
        } catch (FeignException.NotFound ex) {
            logger.error("Entity not found for type {} and ID {}", type, requestDto.getEntityId(), ex);
            throw new ResourceNotFoundException(
                "Target entity not found for type " + type + " and ID " + requestDto.getEntityId()
            );
        } catch (FeignException ex) {
            logger.error("Feign error while validating entity", ex);
            throw new IllegalStateException("Dependent service failure. Please try again.");
        }

        // Step 2: Map and Save Compliance Record
        ComplianceRecord record = new ComplianceRecord();
        record.setEntityId(requestDto.getEntityId());
        record.setType(type);
        record.setResult(
            requestDto.getResult() != null ? requestDto.getResult() : "PENDING"
        );
        record.setDate(LocalDate.now());
        record.setNotes(requestDto.getNotes());

        ComplianceRecord saved = repository.save(record);

        // Step 3: Cleanup NewProgram entry
        Long entityId = requestDto.getEntityId();

        if (!newprogramrepository.existsByEntityId(entityId)) {
            throw new IllegalStateException(
                "No NewProgram entry found for entityId: " + entityId
            );
        }

        newprogramrepository.deleteByEntityId(entityId);

        logger.info(
            "Compliance created and NewProgram entry deleted for entityId {}",
            entityId
        );

        return mapToDTO(saved);
    }

    @Override
    public List<ComplianceResponseDTO> getAllCompliance() {
        return repository.findAll().stream()
                .map(this::mapToDTO)
                .collect(Collectors.toList());
    }

    @Override
    public ComplianceResponseDTO getComplianceById(Long id) {
        ComplianceRecord record = repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Compliance record not found with ID: " + id));
        return mapToDTO(record);
    }

    @Override
    public ComplianceResponseDTO updateCompliance(Long id, ComplianceRequestDTO requestDto) {
        ComplianceRecord existing = repository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Record not found to update with ID: " + id));

        existing.setResult(requestDto.getResult());
        existing.setNotes(requestDto.getNotes());
        existing.setType(requestDto.getType());
        
        return mapToDTO(repository.save(existing));
    }

    @Override
    public void deleteCompliance(Long id) {
        if (!repository.existsById(id)) {
            throw new ResourceNotFoundException("Record not found to delete with ID: " + id);
        }
        repository.deleteById(id);
        logger.info("Compliance record deleted with ID: {}", id);
    }
    
    @Override
    public CulturalProgramResponseDto addNewProgram(CulturalProgramRequestDto dto) {
        logger.info("Service: Creating program: {}", dto.getTitle());
        
        NewProgram program = mapToEntity(dto);
        NewProgram savedProgram = newprogramrepository.save(program);
        
        return mapToResponseDto(savedProgram);
    }
    
    private ComplianceResponseDTO mapToDTO(ComplianceRecord record) {
        ComplianceResponseDTO dto = new ComplianceResponseDTO();
        dto.setComplianceId(record.getComplianceId());
        dto.setEntityId(record.getEntityId());
        dto.setType(record.getType());
        dto.setResult(record.getResult());
        dto.setDate(record.getDate());
        dto.setNotes(record.getNotes());
        return dto;
    }
    
    private NewProgram mapToEntity(CulturalProgramRequestDto dto) {
    	NewProgram entity = new NewProgram();
        entity.setName(dto.getTitle()); // Match Entity field 'name'
        entity.setDescription(dto.getDescription());
        entity.setStartDate(dto.getStartDate());
        entity.setEndDate(dto.getEndDate());
        entity.setBudget(dto.getBudget());
        entity.setStatus(dto.getStatus());
        return entity;
    }
    
    private CulturalProgramResponseDto mapToResponseDto(NewProgram program) {

        Long programId = program.getProgramId();

        return new CulturalProgramResponseDto(
                programId,
                program.getName(),
                program.getDescription(),
                program.getStartDate(),
                program.getEndDate(),
                program.getBudget(),
                program.getStatus()
        );
    }
}